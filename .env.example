# ============================================================
# 몽글픽 AI Agent 환경변수 템플릿 (.env.example)
# ============================================================
# 이 파일을 복사하여 .env로 만든 뒤 실제 값을 입력하세요:
#   cp .env.example .env
# ============================================================

# ── API Keys ──
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
TMDB_API_KEY=your-tmdb-api-key
KOBIS_API_KEY=your-kobis-api-key
KAKAO_API_KEY=your-kakao-api-key

# ── KMDb (한국영화 데이터베이스) ──
KMDB_API_KEY=your-kmdb-api-key
UPSTAGE_API_KEY=your-upstage-api-key

# ── LLM 라우팅 모드 ──
# "hybrid": 몽글이(로컬, 빠른 응답) + Solar API(품질 중요) 혼합
# "local_only": 모든 체인을 Ollama 로컬 모델로 처리 (기존 EXAONE/Qwen 또는 몽글이)
# "api_only": 모든 체인을 Solar API로 처리 (Ollama 장애 시)
LLM_MODE=local_only

# ── Solar API (Upstage, hybrid/api_only 모드에서 사용) ──
# 의도분류, 감정분석, 선호추출, 추천이유, 이미지분석에 사용
SOLAR_API_BASE_URL=https://api.upstage.ai/v1/chat
SOLAR_API_MODEL=solar-pro
SOLAR_API_TIMEOUT=30
SOLAR_API_MAX_RETRIES=2
SOLAR_API_RATE_LIMIT=60

# ── 몽글이 (Solar 10.7B LoRA, hybrid 모드에서 빠른 응답용) ──
# 파인튜닝 전에는 베이스 모델명 사용 가능 (예: solar:10.7b-instruct-v1.0-q4_K_M)
MONGLE_MODEL=mongle
MONGLE_TEMPERATURE=0.5

# ── Ollama (로컬 LLM 서버) ──
OLLAMA_BASE_URL=http://localhost:11434
# 동시에 GPU에 로드할 모델 수
# local_only: 2 (qwen3.5 + exaone-32b), hybrid: 1 (mongle만)
OLLAMA_MAX_LOADED_MODELS=2

# ── LLM Models (Ollama 로컬 모델, local_only 모드 기본값) ──
# 구조화 출력 (의도분류/감정분석/무드태그/이미지분석): Qwen3.5 35B-A3B (MoE)
INTENT_MODEL=qwen3.5:35b-a3b
EMOTION_MODEL=qwen3.5:35b-a3b
MOOD_MODEL=qwen3.5:35b-a3b
# 한국어 생성 (선호추출/대화/추천이유): EXAONE 4.0 32B
PREFERENCE_MODEL=exaone-32b:latest
CONVERSATION_MODEL=exaone-32b:latest
# 경량 한국어 생성 (후속질문): EXAONE 4.0 32B
QUESTION_MODEL=exaone-32b:latest
# Vision (포스터/이미지 분석): Qwen3.5 35B-A3B (비전 내장)
EXPLANATION_MODEL=exaone-32b:latest
VISION_MODEL=qwen3.5:35b-a3b

# ── Qdrant ──
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=movies

# ── Redis ──
REDIS_URL=redis://localhost:6379
# Redis 클라이언트 최대 연결 수 (ConnectionPool)
REDIS_MAX_CONNECTIONS=50

# ── Elasticsearch ──
ELASTICSEARCH_URL=http://localhost:9200

# ── Neo4j ──
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# ── MySQL ──
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=monglepick
MYSQL_USER=monglepick
MYSQL_PASSWORD=your-mysql-password
# MySQL 커넥션 풀 크기 (개발: 1~5, 운영: 5~20 권장)
MYSQL_POOL_MIN=1
MYSQL_POOL_MAX=10

# ── LangSmith (LLM 관측성 + 트레이싱) ──
# https://smith.langchain.com 에서 API 키 발급 후 아래에 입력
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-api-key
LANGCHAIN_PROJECT=monglepick-agent
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ── Session ──
SESSION_TTL_DAYS=30
MAX_CONVERSATION_TURNS=20

# ── Security ──
# Agent → Backend 서비스 인증 키 (Backend application.yml app.service.key와 동일)
SERVICE_API_KEY=dev-service-key-change-me
# JWT 시크릿 키 (Backend application.yml app.jwt.secret과 동일)
JWT_SECRET=monglepick-dev-jwt-secret-key-must-be-at-least-256-bits-long-for-hs256
DAILY_TOKEN_LIMIT=1000000
# CORS 허용 오리진 (*이면 전체 허용, 개발 환경용)
CORS_ALLOWED_ORIGINS=*
# 허용 이미지 MIME 타입 (JPEG, PNG만 허용)
ALLOWED_IMAGE_MIMES=image/jpeg,image/png
# IP당 분당 최대 이미지 업로드 횟수 (chat.py 전용 추가 제한)
IMAGE_UPLOAD_RATE_LIMIT=10
# VLM 동시 처리 수 (GPU 메모리 보호)
VLM_CONCURRENCY_LIMIT=2
# Pillow DecompressionBomb 방어 (25MP)
IMAGE_MAX_PIXELS=25000000

# ── 전역 API Rate Limiting (RateLimitMiddleware) ──
# 비인증 사용자(IP 기반) 분당 최대 요청 수
RATE_LIMIT_ANON_RPM=30
# 인증 사용자(Bearer 토큰 기반) 분당 최대 요청 수
RATE_LIMIT_AUTH_RPM=60

# ── 요청 타임아웃 (TimeoutMiddleware) ──
# SSE 엔드포인트(/api/v1/chat, /api/v1/match) 타임아웃 (초)
# LangGraph 전체 그래프 실행 + 스트리밍 여유분 포함
TIMEOUT_SSE_SEC=300
# 일반 엔드포인트 타임아웃 (초)
TIMEOUT_DEFAULT_SEC=30

# ── 관리자 AI 에이전트 Checkpointer (Step 7c) ──
# false(기본): MemorySaver. true: AsyncRedisSaver (다중 인스턴스 세션 공유)
ADMIN_REDIS_CHECKPOINTER_ENABLED=false

# ── 고객센터 AI 에이전트 Checkpointer (Phase 3 RedisSaver) ──
# false(기본): MemorySaver — 단일 프로세스 내 thread_id 격리. 재시작 시 세션 소멸.
# true: AsyncRedisSaver — 멀티 인스턴스 배포 + 재시작 후에도 세션 유지 (TTL 24h).
# 키 prefix: support_assistant:checkpoint / cp_blob / cp_write (admin_assistant 와 격리됨)
SUPPORT_REDIS_CHECKPOINTER_ENABLED=false

# ── 관리자 AI 에이전트 Tool 카테고리 필터 (Step 7a 재설계) ──
# tool_selector 가 LLM 에 bind 할 tool 후보를 카테고리·키워드 힌트로 축소한다.
# intent_kind (stats|query|action) + 이름 컨벤션(stats_*, dashboard_*, *_draft, goto_*)
# + 사용자 발화 키워드로 76 tool → 20~30 tool 로 자동 축소.
# Qdrant/임베딩 불필요 — 추가 인프라·비용 0.
# 상한만 조정 가능. 필터가 실패하면 role 전체로 자동 폴백.
ADMIN_TOOL_FILTER_MAX=30
