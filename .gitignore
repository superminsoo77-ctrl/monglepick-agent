# ============================================================
# 몽글픽 AI Agent .gitignore
# ============================================================

# ── 환경 변수 / 시크릿 (최우선 차단) ──
.env
.env.*
!.env.example
*.pem
*.key
*.secret

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg

# ── 가상환경 ──
.venv/
venv/
ENV/

# ── 대용량 데이터 (파이프라인 산출물, 재생성 가능) ──
data/
*.csv
*.tsv
*.parquet
*.pickle
*.pkl
*.xlsx

# ── IDE / 에디터 ──
.idea/
.vscode/
*.swp
*.swo
*~

# ── OS 시스템 파일 ──
.DS_Store
Thumbs.db
Desktop.ini

# ── Claude Code ──
.claude/

# ── Docker ──
docker-compose.override.yml

# ── 테스트 / 커버리지 ──
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# ── Jupyter ──
.ipynb_checkpoints/

# ── Logs ──
*.log
