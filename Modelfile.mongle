# =============================================================================
# Modelfile.mongle — 몽글이 Ollama 모델 정의 (M-LLM-5)
#
# [개요]
#   EXAONE 4.0 1.2B LoRA 파인튜닝 모델 "몽글이"를 Ollama에 등록하는 설정 파일.
#   몽글이는 텍스트 '생성(말하기)' 전담 — 일반 대화 응답, 후속 질문 생성.
#   분석/추론(의도 분류, 선호 추출, 추천 이유)은 Solar API가 담당.
#
# [등록 방법]
#   # 파인튜닝 완료 후 (merge_and_convert.py 실행 후)
#   ollama create mongle -f Modelfile.mongle
#
#   # 또는 merge_and_convert.py --register_ollama 플래그로 자동 등록
#   python scripts/merge_and_convert.py \
#     --lora_path models/mongle-lora \
#     --output_gguf models/mongle-exaone4-q4km.gguf \
#     --register_ollama --modelfile Modelfile.mongle
#
# [테스트]
#   ollama run mongle
#   > 안녕! 오늘 우울한데 영화 추천해줘
#
# [Ollama API 확인]
#   curl http://localhost:11434/api/tags | python3 -m json.tool | grep mongle
#
# [파인튜닝 없이 베이스 모델만 사용 (개발/테스트용)]
#   EXAONE 4.0 1.2B 공식 GGUF 사용:
#   1. Modelfile 첫 줄을 아래로 변경:
#      FROM LGAI-EXAONE/EXAONE-4.0-1.2B-GGUF:Q4_K_M
#   2. ollama create mongle -f Modelfile.mongle
#
# [참고]
#   - 설계서: docs/몽글이_하이브리드_LLM_설계서.md §3-5
#   - GGUF 생성: scripts/merge_and_convert.py
#   - Ollama Modelfile 문서: https://github.com/ollama/ollama/blob/main/docs/modelfile.md
# =============================================================================

# ─── 베이스 GGUF ────────────────────────────────────────────────────────────
# merge_and_convert.py가 생성한 Q4_K_M 양자화 모델 사용
# 크기: ~0.8GB | VRAM: ~1GB (T4 15GB의 6.7% — 15GB 여유)
# 응답 속도: ~50+ tok/s (T4), ~80+ tok/s (M-series Apple Silicon)
#
# 주의: merge_and_convert.py --register_ollama 사용 시 이 경로가 절대경로로
#       자동 치환된 임시 Modelfile이 생성됩니다.
FROM ./models/mongle-exaone4-q4km.gguf

# ─── 몽글이 시스템 프롬프트 ─────────────────────────────────────────────────
# 역할: 영화 추천 서비스 몽글픽의 AI 어시스턴트
# 담당: 일반 대화 응답, 후속 질문 생성 (텍스트 생성 전용)
# 제외: 의도 분류, 선호 추출, 추천 이유 생성 (Solar API 담당)
SYSTEM """당신은 '몽글이'입니다. 영화 추천 서비스 '몽글픽'의 AI 어시스턴트입니다.

성격:
- 친근하고 따뜻한 말투 (존댓말 기본)
- 영화에 대한 열정과 깊은 지식
- 사용자의 감정에 공감하며 대화

규칙:
- 영화 추천 시 구체적인 이유를 함께 설명
- 사용자의 취향을 존중하며 다양한 선택지 제공
- 스포일러 주의
- 한국어로 자연스럽게 대화
"""

# ─── 생성 파라미터 (1.2B 소형 모델 최적화) ──────────────────────────────────

# temperature: 0.5 — 창의성과 일관성의 균형
# 너무 낮으면 (0.1~0.2) 반복적이고 딱딱한 응답
# 너무 높으면 (0.8~1.0) 맥락 벗어난 응답 위험
# 몽글이 역할(친근한 대화)에는 0.5가 적합
PARAMETER temperature 0.5

# top_p: 0.9 — 누적 확률 90% 이내 토큰만 샘플링 (Nucleus Sampling)
# 너무 낮으면 다양성 감소, 너무 높으면 품질 저하
PARAMETER top_p 0.9

# top_k: 40 — 상위 40개 토큰만 샘플링 후보로 고려
# 소형 모델(1.2B)에서 40은 충분한 다양성 확보
PARAMETER top_k 40

# repeat_penalty: 1.1 — 반복 토큰에 페널티 부여
# 1.0 = 패널티 없음, 1.1 = 약한 패널티 (소형 모델의 반복 경향 억제)
# 너무 높으면 (1.3+) 문장이 어색해짐
PARAMETER repeat_penalty 1.1

# num_ctx: 4096 — 컨텍스트 윈도우 크기 (토큰)
# 멀티턴 대화 이력 + 시스템 프롬프트 = 충분한 크기
# 1.2B 모델 VRAM 여유 범위 내 (4096 × 2bytes ≈ 8MB)
PARAMETER num_ctx 4096

# ─── 종료 토큰 (EXAONE 4.0 채팅 템플릿) ────────────────────────────────────
# EXAONE 4.0 공식 종료 토큰 — 채팅 턴 경계 구분
# [|endofturn|] : 각 역할(system/user/assistant) 발화 종료 시 사용
# [|endoftext|] : 전체 시퀀스 종료 (EOS 역할)
PARAMETER stop "<|end_of_turn|>"
PARAMETER stop "<|endoftext|>"
